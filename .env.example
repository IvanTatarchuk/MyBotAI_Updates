# Environment Configuration
NODE_ENV=production
CLIENT_URL=http://localhost:3000
VITE_API_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=secure_password_123
DB_NAME=trading_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_password_123

# JWT Configuration
JWT_SECRET=super_secure_jwt_secret_key_2024_change_this_in_production
JWT_REFRESH_SECRET=super_secure_refresh_secret_key_2024_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Exchange API Keys (Get these from respective exchanges)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Payment Processing
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# AI/ML Services
OPENAI_API_KEY=sk-your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Monitoring and Analytics
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
VITE_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
VITE_ANALYTICS_ID=your_google_analytics_id_here

# Grafana Configuration
GRAFANA_PASSWORD=admin123

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# Feature Flags
ENABLE_AI_PREDICTIONS=true
ENABLE_SOCIAL_TRADING=true
ENABLE_COPY_TRADING=true
ENABLE_LEVERAGE_TRADING=true
ENABLE_MARGIN_TRADING=true

# Trading Configuration
DEFAULT_LEVERAGE=1
MAX_LEVERAGE=100
MIN_TRADE_AMOUNT=10
MAX_TRADE_AMOUNT=1000000

# Notification Configuration
PUSH_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_ENABLED=true
SMS_NOTIFICATION_ENABLED=true

# API Configuration
API_RATE_LIMIT=1000
API_RATE_WINDOW=900000

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_CONNECTION_TIMEOUT=60000

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# SSL Configuration (for production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/private.key

# Load Balancer Configuration
LOAD_BALANCER_ENABLED=false
LOAD_BALANCER_ALGORITHM=round_robin

# Kubernetes Configuration (if using K8s)
KUBERNETES_NAMESPACE=trading-platform
KUBERNETES_CLUSTER=trading-cluster